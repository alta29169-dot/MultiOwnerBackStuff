-- ============================================================
--  AimDiag_Passive_High.lua 2
--  Target is placed 300 studs ABOVE your ship to avoid ocean floor.
--  You drive closer manually; the script aims, fires, and logs.
-- ============================================================
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local SHIP_TYPES = { "Destroyer", "Cruiser", "Heavy Cruiser" }
local FIRE_INTERVAL = 4          -- seconds between shots
local TARGET_Y_OFFSET = 300      -- studs above your ship's starting Y

-- ---------- Find my ship ----------
local function findMyShip()
    for _, shipType in ipairs(SHIP_TYPES) do
        for _, ship in ipairs(workspace:GetChildren()) do
            if ship:IsA("Model") and ship.Name == shipType then
                local ownerVal = ship:FindFirstChild("Owner")
                if ownerVal and ownerVal:IsA("StringValue") and ownerVal.Value == LocalPlayer.Name then
                    return ship
                end
            end
        end
    end
    return nil
end

-- ---------- Seat ----------
local function seatInShip(ship)
    local seat = ship:FindFirstChild("Seat")
    if not seat then return false end
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    local hum = char:WaitForChild("Humanoid")
    hrp.CFrame = seat.CFrame + Vector3.new(0, 2, 0)
    task.wait(0.3)
    seat:Sit(hum)
    return true
end

-- ---------- Create a high target ----------
local function createTarget(shipMainBody)
    local target = Instance.new("Part")
    target.Name = "AimTarget"
    target.Anchored = true
    target.CanCollide = false
    target.Size = Vector3.new(20, 20, 20)
    target.BrickColor = BrickColor.new("Lime green")
    target.Transparency = 0.3
    target.Parent = workspace

    -- Place 800 studs ahead, 300 studs above ship's current Y
    local forwardPos = shipMainBody.Position + shipMainBody.CFrame.LookVector * 1750
    target.Position = Vector3.new(forwardPos.X, shipMainBody.Position.Y + TARGET_Y_OFFSET, forwardPos.Z)
    return target
end

-- ---------- Main loop ----------
local function runDiagnostic(ship)
    local mainBody = ship:FindFirstChild("MainBody")
    if not mainBody then warn("No MainBody"); return end

    local target = createTarget(mainBody)
    local targetPos = target.Position
    print("[Diag] Target placed HIGH at:", targetPos)

    -- Remove AlignOrientation (harmless, helps aim)
    local align = mainBody:FindFirstChild("AlignOrientation")
    if align then align:Destroy() end

    -- Bullet tracking
    local lastBulletPos = nil
    local bulletReceived = false
    local bulletConn
    bulletConn = workspace.ChildAdded:Connect(function(child)
        if child.Name == "bullet" and child:IsA("BasePart") then
            lastBulletPos = child.Position
            bulletReceived = true
            child:Destroy()
        end
    end)

    local lastFireTime = 0
    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not ship.Parent then
            conn:Disconnect()
            bulletConn:Disconnect()
            target:Destroy()
            print("[Diag] Ship destroyed – stopping.")
            return
        end

        local now = tick()
        if now - lastFireTime >= FIRE_INTERVAL then
            -- Aim at target center
            pcall(function()
                ReplicatedStorage.Event:FireServer("aim", { targetPos })
            end)
            task.wait(0.2)

            bulletReceived = false
            lastBulletPos = nil
            pcall(function()
                ReplicatedStorage.Event:FireServer("bomb", { true })
            end)
            lastFireTime = now

            task.wait(0.5)  -- let bullet appear

            local dist = (mainBody.Position - targetPos).Magnitude
            if bulletReceived and lastBulletPos then
                local yOffset = lastBulletPos.Y - targetPos.Y
                local hOffset = (Vector3.new(lastBulletPos.X, 0, lastBulletPos.Z) - Vector3.new(targetPos.X, 0, targetPos.Z)).Magnitude
                print(string.format("Dist: %6.1f | Y-offset: %6.1f | H-offset: %6.1f", dist, yOffset, hOffset))
            else
                print(string.format("Dist: %6.1f | (no bullet detected)", dist))
            end
        end
    end)
end

-- ---------- Entry ----------
local function start()
    print("[Diag] Looking for ship...")
    local ship = findMyShip()
    if not ship then warn("No ship found"); return end
    if not seatInShip(ship) then return end
    task.wait(1)
    runDiagnostic(ship)
    print("[Diag] Running. A green cube is 800 studs ahead, 300 studs above you.")
    print("[Diag] Drive toward it manually. Data will appear here every 4 seconds.")
end

start()
