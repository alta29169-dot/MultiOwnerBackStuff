-- ============================================================
--  AimFactorTuner.lua w22
--  GUI with a "Factor" input.  Fires at nearest enemy every 4s.
--  Uses: aimPos = enemyBody.Position + Vector3(0, factor * dist, 0)
--  Logs distance, factor, and the resulting Y‑offset.
-- ============================================================
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local SHIP_TYPES = { "Destroyer", "Cruiser", "Heavy Cruiser" }
local FIRE_INTERVAL = 4   -- seconds between shots

-- ---------- GUI ----------
local function createGui()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "AimFactorTunerGui"
    screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 200, 0, 60)
    frame.Position = UDim2.new(0, 20, 0, 20)
    frame.BackgroundColor3 = Color3.new(0, 0, 0)
    frame.BackgroundTransparency = 0.5
    frame.Parent = screenGui

    local label = Instance.new("TextLabel")
    label.Text = "Factor (e.g. 0.055):"
    label.Size = UDim2.new(0, 100, 0, 20)
    label.Position = UDim2.new(0, 5, 0, 5)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = Enum.Font.SourceSans
    label.TextSize = 14
    label.Parent = frame

    local factorBox = Instance.new("TextBox")
    factorBox.Size = UDim2.new(0, 70, 0, 20)
    factorBox.Position = UDim2.new(0, 110, 0, 5)
    factorBox.Text = "0.055"   -- default based on 100/1800
    factorBox.BackgroundColor3 = Color3.new(0.3, 0.3, 0.3)
    factorBox.TextColor3 = Color3.new(1, 1, 1)
    factorBox.Font = Enum.Font.SourceSans
    factorBox.TextSize = 14
    factorBox.Parent = frame

    local info = Instance.new("TextLabel")
    info.Text = "Aim at nearest enemy every 4s"
    info.Size = UDim2.new(0, 180, 0, 20)
    info.Position = UDim2.new(0, 5, 0, 30)
    info.BackgroundTransparency = 1
    info.TextColor3 = Color3.new(0.8, 0.8, 0.8)
    info.Font = Enum.Font.SourceSans
    info.TextSize = 12
    info.Parent = frame

    return factorBox
end

-- ---------- Find my ship ----------
local function findMyShip()
    for _, shipType in ipairs(SHIP_TYPES) do
        for _, ship in ipairs(workspace:GetChildren()) do
            if ship:IsA("Model") and ship.Name == shipType then
                local ownerVal = ship:FindFirstChild("Owner")
                if ownerVal and ownerVal:IsA("StringValue") and ownerVal.Value == LocalPlayer.Name then
                    return ship
                end
            end
        end
    end
    return nil
end

-- ---------- Seat ----------
local function seatInShip(ship)
    local seat = ship:FindFirstChild("Seat")
    if not seat then return false end
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    local hum = char:WaitForChild("Humanoid")
    hrp.CFrame = seat.CFrame + Vector3.new(0, 2, 0)
    task.wait(0.3)
    seat:Sit(hum)
    return true
end

-- ---------- Find nearest enemy ship ----------
local function findEnemyShip(myTeam)
    local bestDist = math.huge
    local bestShip = nil
    for _, shipType in ipairs(SHIP_TYPES) do
        for _, ship in ipairs(workspace:GetChildren()) do
            if ship:IsA("Model") and ship.Name == shipType then
                local teamVal = ship:FindFirstChild("Team")
                if teamVal and teamVal:IsA("StringValue") and teamVal.Value ~= myTeam then
                    local mainBody = ship:FindFirstChild("MainBody")
                    if mainBody then
                        local myPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                                      and LocalPlayer.Character.HumanoidRootPart.Position or Vector3.zero
                        local dist = (mainBody.Position - myPos).Magnitude
                        if dist < bestDist then
                            bestDist = dist
                            bestShip = ship
                        end
                    end
                end
            end
        end
    end
    return bestShip
end

-- ---------- Main ----------
local function start()
    print("[AimFactorTuner] Looking for ship...")
    local ship = findMyShip()
    if not ship then warn("No ship found"); return end
    if not seatInShip(ship) then return end
    task.wait(0.5)

    local factorBox = createGui()
    local myTeam = (ship:FindFirstChild("Team") and ship:FindFirstChild("Team").Value) or ""
    local lastFireTime = 0

    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not ship.Parent then
            conn:Disconnect()
            print("[AimFactorTuner] Ship destroyed.")
            return
        end

        local now = tick()
        if now - lastFireTime >= FIRE_INTERVAL then
            local enemyShip = findEnemyShip(myTeam)
            if enemyShip then
                local enemyBody = enemyShip:FindFirstChild("MainBody")
                if enemyBody then
                    -- Distance to enemy
                    local myPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                                  and LocalPlayer.Character.HumanoidRootPart.Position or Vector3.zero
                    local dist = (enemyBody.Position - myPos).Magnitude

                    -- Factor from GUI
                    local factor = tonumber(factorBox.Text) or 0
                    local yOffset = factor * dist

                    local aimPos = enemyBody.Position + Vector3.new(0, yOffset, 0)

                    pcall(function()
                        ReplicatedStorage.Event:FireServer("aim", { aimPos })
                    end)
                    task.wait(0.2)
                    pcall(function()
                        ReplicatedStorage.Event:FireServer("bomb", { true })
                    end)

                    print(string.format("Fired at %s | Dist: %.0f | Factor: %.4f | Y-offset: %.1f",
                        enemyShip.Name, dist, factor, yOffset))
                    lastFireTime = now
                end
            else
                task.wait(2)
                lastFireTime = tick()
            end
        end
    end)
end

start()
