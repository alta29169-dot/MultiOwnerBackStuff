-- ============================================================
--  AimTuner.lua
--  GUI with a Y‑offset box.  Shoot nearest enemy every 4s.
--  Logs distance + offset used.  Tune until you see hits.
-- ============================================================
local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local LocalPlayer = Players.LocalPlayer

local SHIP_TYPES = { "Destroyer", "Cruiser", "Heavy Cruiser" }
local FIRE_INTERVAL = 4   -- seconds

-- ---------- GUI ----------
local function createGui()
    local screenGui = Instance.new("ScreenGui")
    screenGui.Name = "AimTunerGui"
    screenGui.Parent = LocalPlayer:WaitForChild("PlayerGui")

    local frame = Instance.new("Frame")
    frame.Size = UDim2.new(0, 180, 0, 60)
    frame.Position = UDim2.new(0, 20, 0, 20)
    frame.BackgroundColor3 = Color3.new(0, 0, 0)
    frame.BackgroundTransparency = 0.5
    frame.Parent = screenGui

    local label = Instance.new("TextLabel")
    label.Text = "Y Offset:"
    label.Size = UDim2.new(0, 60, 0, 20)
    label.Position = UDim2.new(0, 5, 0, 5)
    label.BackgroundTransparency = 1
    label.TextColor3 = Color3.new(1, 1, 1)
    label.Font = Enum.Font.SourceSans
    label.TextSize = 14
    label.Parent = frame

    local textBox = Instance.new("TextBox")
    textBox.Size = UDim2.new(0, 80, 0, 20)
    textBox.Position = UDim2.new(0, 70, 0, 5)
    textBox.Text = "0"
    textBox.BackgroundColor3 = Color3.new(0.3, 0.3, 0.3)
    textBox.TextColor3 = Color3.new(1, 1, 1)
    textBox.Font = Enum.Font.SourceSans
    textBox.TextSize = 14
    textBox.Parent = frame

    local infoLabel = Instance.new("TextLabel")
    infoLabel.Text = "Aim at nearest enemy every 4s"
    infoLabel.Size = UDim2.new(0, 170, 0, 20)
    infoLabel.Position = UDim2.new(0, 5, 0, 30)
    infoLabel.BackgroundTransparency = 1
    infoLabel.TextColor3 = Color3.new(0.8, 0.8, 0.8)
    infoLabel.Font = Enum.Font.SourceSans
    infoLabel.TextSize = 12
    infoLabel.Parent = frame

    return textBox
end

-- ---------- Find my ship ----------
local function findMyShip()
    for _, shipType in ipairs(SHIP_TYPES) do
        for _, ship in ipairs(workspace:GetChildren()) do
            if ship:IsA("Model") and ship.Name == shipType then
                local ownerVal = ship:FindFirstChild("Owner")
                if ownerVal and ownerVal:IsA("StringValue") and ownerVal.Value == LocalPlayer.Name then
                    return ship
                end
            end
        end
    end
    return nil
end

-- ---------- Seat ----------
local function seatInShip(ship)
    local seat = ship:FindFirstChild("Seat")
    if not seat then return false end
    local char = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
    local hrp = char:WaitForChild("HumanoidRootPart")
    local hum = char:WaitForChild("Humanoid")
    hrp.CFrame = seat.CFrame + Vector3.new(0, 2, 0)
    task.wait(0.3)
    seat:Sit(hum)
    return true
end

-- ---------- Find nearest enemy ship ----------
local function findEnemyShip(myTeam)
    local bestDist = math.huge
    local bestShip = nil
    for _, shipType in ipairs(SHIP_TYPES) do
        for _, ship in ipairs(workspace:GetChildren()) do
            if ship:IsA("Model") and ship.Name == shipType then
                local teamVal = ship:FindFirstChild("Team")
                if teamVal and teamVal:IsA("StringValue") and teamVal.Value ~= myTeam then
                    local mainBody = ship:FindFirstChild("MainBody")
                    if mainBody then
                        local myPos = LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                                      and LocalPlayer.Character.HumanoidRootPart.Position or Vector3.zero
                        local dist = (mainBody.Position - myPos).Magnitude
                        if dist < bestDist then
                            bestDist = dist
                            bestShip = ship
                        end
                    end
                end
            end
        end
    end
    return bestShip
end

-- ---------- Main ----------
local function start()
    print("[AimTuner] Looking for ship...")
    local ship = findMyShip()
    if not ship then warn("No ship found"); return end
    if not seatInShip(ship) then return end
    task.wait(0.5)

    local offsetBox = createGui()
    local myTeam = (ship:FindFirstChild("Team") and ship:FindFirstChild("Team").Value) or ""
    local lastFireTime = 0

    local conn
    conn = RunService.Heartbeat:Connect(function()
        if not ship.Parent then
            conn:Disconnect()
            print("[AimTuner] Ship destroyed.")
            return
        end

        local now = tick()
        if now - lastFireTime >= FIRE_INTERVAL then
            local enemyShip = findEnemyShip(myTeam)
            if enemyShip then
                local enemyBody = enemyShip:FindFirstChild("MainBody")
                if enemyBody then
                    local offset = tonumber(offsetBox.Text) or 0
                    local aimPos = enemyBody.Position + Vector3.new(0, offset, 0)

                    pcall(function()
                        ReplicatedStorage.Event:FireServer("aim", { aimPos })
                    end)
                    task.wait(0.2)
                    pcall(function()
                        ReplicatedStorage.Event:FireServer("bomb", { true })
                    end)

                    local dist = (LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("HumanoidRootPart")
                                  and LocalPlayer.Character.HumanoidRootPart.Position or Vector3.zero - enemyBody.Position).Magnitude
                    print(string.format("Fired at %s | Dist: %.0f | Y-offset: %.0f", enemyShip.Name, dist, offset))
                    lastFireTime = now
                end
            else
                -- No enemy, wait a bit longer to avoid spam
                task.wait(2)
                lastFireTime = tick()
            end
        end
    end)
end

start()
